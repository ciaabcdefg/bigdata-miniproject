# ===== Bigdata Pipeline Configuration =====

# Kafka
KAFKA_BROKER=kafka:9092
KAFKA_TOPIC=service-logs

# Elasticsearch
ES_HOST=elasticsearch
ES_PORT=9200
ES_ERROR_INDEX=error-counts
ES_REQUEST_INDEX=request-counts

# Spark
SPARK_MASTER=spark://spark-master:7077

# Log Generator
LOG_INTERVAL_MIN=0.05
LOG_INTERVAL_MAX=0.05

# Versions
CONFLUENT_VERSION=7.5.0
ES_VERSION=8.11.0
SPARK_VERSION=latest
HADOOP_VERSION=2.0.0-hadoop3.2.1-java8
